@startuml C4_Component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Pet Care Reminder System — Component Diagram

Container_Boundary(app, "Pet Care Reminder Application") {

    Component(consoleApp, "ConsoleApp", "Java Class", "Main console application with keyboard-navigable menus for Pet, Reminder, Vet, Medical, and Settings screens.")
    Component(mainFrame, "MainFrame", "Java Swing JFrame", "Main GUI window containing NavPanel, DashboardPanel, PetsPanel, RemindersPanel, MedicalPanel, VetPanel, and SettingsPanel.")

    Component(petService, "PetService", "Java Class", "Business logic for Pet CRUD operations. Validates input and publishes events via EventManager.")
    Component(reminderService, "ReminderService", "Java Class", "Business logic for Reminder CRUD. Handles scheduling, completion, and overdue detection.")
    Component(medicalService, "MedicalRecordService", "Java Class", "Business logic for medical record management. CRUD for vaccinations, checkups, surgeries.")
    Component(userService, "UserService", "Java Class", "Handles user authentication: login, register, findByUsername. Password hashing for security.")

    Component(eventMgr, "EventManager", "Singleton Pattern", "Observer Pattern subject. Manages event subscriptions and dispatches notifications to all registered observers.")
    Component(observer, "PetReminderObserver", "Interface", "Observer interface with onEvent(EventType, Object) callback method.")

    Component(iRepo, "IRepository<T>", "Interface", "Generic CRUD interface: save, findById, findAll, update, delete, deleteAll, count, close.")
    Component(repoFactory, "RepositoryFactory", "Factory Method Pattern", "Creates the appropriate repository implementation based on the active StorageType configuration. Supports reinitialize() for backend switching.")
    Component(binaryRepo, "BinaryRepository<T>", "Java Class", "Stores entities as serialized binary .dat files using Java ObjectOutputStream.")
    Component(sqliteRepo, "SqliteRepository<T>", "Abstract Class", "SQLite JDBC-based storage with concrete subclasses for Pet, Reminder, User, and MedicalRecord.")
    Component(mysqlRepo, "MySqlRepository<T>", "Abstract Class", "MySQL JDBC-based storage via Docker Compose with concrete subclasses for each entity type.")

    Component(storageConfig, "StorageConfig", "Java Class", "Holds the active storage backend setting. Supports runtime switching between Binary, SQLite, and MySQL. Persists to storage.properties.")

    Component(exceptions, "Exception Hierarchy", "Java Classes", "PetReminderException (base), ValidationException, StorageException, ConnectionException, EntityNotFoundException, PetNotFoundException, ReminderNotFoundException, ServiceException.")

    Component(models, "Domain Models", "Java Classes", "Pet (abstract), Dog, Cat, Bird, Reminder (abstract), FeedingReminder, MedicationReminder, VetAppointment, GroomingReminder, ExerciseReminder, MedicalRecord, User.")
}

ContainerDb(binaryStore, "Binary Storage", "Java Serialization", "Local .dat files in data/binary/")
ContainerDb(sqliteDb, "SQLite Database", "SQLite 3 / JDBC", "petreminder.db")
ContainerDb(mysqlDb, "MySQL Database", "MySQL 8 / Docker", "Port 3306")

Rel(consoleApp, petService, "Uses")
Rel(consoleApp, reminderService, "Uses")
Rel(consoleApp, medicalService, "Uses")
Rel(consoleApp, userService, "Uses")
Rel(mainFrame, petService, "Uses")
Rel(mainFrame, reminderService, "Uses")
Rel(mainFrame, medicalService, "Uses")
Rel(mainFrame, observer, "Implements")

Rel(petService, iRepo, "CRUD operations")
Rel(reminderService, iRepo, "CRUD operations")
Rel(medicalService, iRepo, "CRUD operations")
Rel(userService, iRepo, "CRUD operations")

Rel(petService, eventMgr, "Publishes events")
Rel(reminderService, eventMgr, "Publishes events")

Rel(eventMgr, observer, "Notifies via onEvent()")

Rel(repoFactory, binaryRepo, "Creates")
Rel(repoFactory, sqliteRepo, "Creates")
Rel(repoFactory, mysqlRepo, "Creates")
Rel(repoFactory, storageConfig, "Reads active backend")

Rel(binaryRepo, iRepo, "Implements")
Rel(sqliteRepo, iRepo, "Implements")
Rel(mysqlRepo, iRepo, "Implements")

Rel(petService, models, "Uses")
Rel(reminderService, models, "Uses")

Rel(petService, exceptions, "Throws PetNotFoundException, ValidationException")
Rel(reminderService, exceptions, "Throws ReminderNotFoundException")
Rel(binaryRepo, exceptions, "Throws StorageException")
Rel(mysqlRepo, exceptions, "Throws ConnectionException")

Rel(binaryRepo, binaryStore, "Reads/Writes")
Rel(sqliteRepo, sqliteDb, "Reads/Writes")
Rel(mysqlRepo, mysqlDb, "Reads/Writes")

@enduml
