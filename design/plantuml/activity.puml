@startuml PetReminderActivityDiagram
title Pet Care Reminder System — Ana Akış

start

:Uygulama Başlatılır;
:StorageConfig yüklenir;
:RepositoryFactory aktif backend'i belirler;

if (GUI modu mu?) then (Evet)
  :MainFrame açılır (Swing);
else (Hayır)
  :ConsoleApp başlatılır;
endif

repeat
  :Ana Menü Gösterilir;

  switch (Kullanıcı Seçimi?)
  case (Pet Yönetimi)
    :Pet alt menüsü açılır;
    split
      :Yeni Pet Ekle;
      :Pet bilgileri girilir;
      :validatePet() çalışır;
      if (Doğrulama başarılı?) then (Evet)
        :repository.save(pet);
        :EventManager.notify(PET_ADDED);
        :Başarı mesajı;
      else (Hayır)
        :Hata mesajı gösterilir;
      endif
    split again
      :Pet Listele;
      :repository.findAll();
      :Tablo gösterilir;
    split again
      :Pet Güncelle;
      :repository.update(pet);
      :EventManager.notify(PET_UPDATED);
    split again
      :Pet Sil;
      :repository.delete(id);
      :EventManager.notify(PET_DELETED);
    end split

  case (Hatırlatıcı Yönetimi)
    :Hatırlatıcı alt menüsü açılır;
    split
      :Yeni Hatırlatıcı Ekle;
      :Tür seçilir (Feeding/Medication/Vet/Grooming/Exercise);
      :Zamanlama bilgisi girilir;
      :repository.save(reminder);
      :EventManager.notify(REMINDER_ADDED);
    split again
      :Hatırlatıcıları Listele;
      :repository.findAll();
    split again
      :Tamamlandı İşaretle;
      :reminder.setCompleted(true);
      :repository.update(reminder);
      :EventManager.notify(REMINDER_COMPLETED);
    end split

  case (Tıbbi Kayıtlar)
    :MedicalRecord alt menüsü;
    split
      :Yeni Kayıt Ekle;
      :Teşhis ve tedavi bilgisi girilir;
      :repository.save(record);
    split again
      :Kayıtları Görüntüle;
      :Pet'e göre filtreleme;
    end split

  case (Ayarlar)
    :Ayarlar menüsü açılır;
    :Storage backend seçimi;
    :StorageConfig.setActiveBackend();
    :RepositoryFactory yeniden yapılandırılır;
    :Başarı mesajı;

  case (Çıkış)
    :Repository bağlantıları kapatılır;
    stop
  endswitch

repeat while (Devam?) is (Evet)

stop

@enduml
