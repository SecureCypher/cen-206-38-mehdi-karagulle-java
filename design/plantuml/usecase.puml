@startuml PetReminderUseCase
actor "User (Pet Owner)" as User

rectangle "Pet Care Reminder System" {
  usecase "Manage Pets" as UC1
  usecase "Add New Pet" as UC1_1
  usecase "View Pet Details" as UC1_2
  
  usecase "Manage Reminders" as UC2
  usecase "Add Feeding/Med/Vet Reminder" as UC2_1
  usecase "Mark Reminder as Complete" as UC2_2
  
  usecase "Monitor Health" as UC3
  usecase "View Medical Records" as UC3_1
  
  usecase "System Settings" as UC4
  usecase "Switch Storage Backend (Binary/SQLite/MySQL)" as UC4_1
}

User --> UC1
UC1 ..> UC1_1 : includes
UC1 ..> UC1_2 : includes

User --> UC2
UC2 ..> UC2_1 : includes
UC2 ..> UC2_2 : includes

User --> UC3
UC3 ..> UC3_1 : includes

User --> UC4
UC4 ..> UC4_1 : includes

@enduml
