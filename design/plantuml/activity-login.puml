    else (no)
        :Display "Username already taken.";
        :Return to Authentication Menu;
    endif

case (Guest Mode)
    :Create temporary session;
    :Display "Entering as guest.\nData will not be saved.";
    :Navigate to Main Menu;
endswitch

stop

@enduml
